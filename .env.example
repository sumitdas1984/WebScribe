# WebScribe Environment Configuration
# Copy this file to .env and fill in your actual values

# LLM API Configuration
# Get your API key from: https://platform.openai.com/api-keys
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Database (optional - defaults to sqlite in project directory)
# DATABASE_URL=sqlite:///webscribe.db

# API Server (optional)
# API_HOST=0.0.0.0
# API_PORT=8000

# Knowledge Base Directory (optional)
# KB_DIR=./knowledge_base

# Scraper Configuration (optional)
# STATIC_SCRAPER_TIMEOUT=30
# DYNAMIC_SCRAPER_TIMEOUT=30

# Worker Configuration (optional)
# MAX_CONCURRENT_JOBS=5

# AI Engine Configuration (optional)
# AI_RETRY_COUNT=3
# AI_RETRY_BASE_DELAY=1.0

# De-noiser Configuration (optional)
# MIN_CONTENT_LENGTH=50
